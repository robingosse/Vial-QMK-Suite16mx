{
    "features": {
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
        "via": true,
        "vial": true,
        "encoder": true,
        "rgb_matrix": false,
        "rgblight": false,
        "backlight": false,
        "oled": false,
        "audio": false,
        "led_matrix": false
    },

    "matrix_pins": {
        "direct": [
            ["GP4", "GP5", "GP6", "GP9"],
            ["GP3", "GP2", "GP1", "GP0"]
        ]
    },

    "encoder": {
        "rotary": [
            {
                "pin_a": "GP7",
                "pin_b": "GP8",
                "resolution": 4
            }
        ]
    },

    "layouts": {
        "LAYOUT": {
            "layout": [
                {
                    "matrix": [0, 0],
                    "x": 0,
                    "y": 0
                },
                {
                    "matrix": [0, 1],
                    "x": 1,
                    "y": 0
                },
                {
                    "matrix": [0, 2],
                    "x": 2,
                    "y": 0
                },
                {
                    "matrix": [0, 3],
                    "x": 3,
                    "y": 0,
                    "encoder": 0
                },

                {
                    "matrix": [1, 0],
                    "x": 0,
                    "y": 1
                },
                {
                    "matrix": [1, 1],
                    "x": 1,
                    "y": 1
                },
                {
                    "matrix": [1, 2],
                    "x": 2,
                    "y": 1
                },
                {
                    "matrix": [1, 3],
                    "x": 3,
                    "y": 1
                }
            ]
        }
    }
}
